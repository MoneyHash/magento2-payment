{
    "name": "moneyhash/magento2-payment",
    "description": "MoneyHash Payment Gateway Integration for Magento 2 - Secure, unified payments processing platform",
    "type": "magento2-module",
    "version": "1.0.1",
    "license": [
        "proprietary"
    ],
    "require": {
        "php": "~8.1.0|~8.2.0|~8.3.0|~8.4.0",
        "magento/framework": "^103.0|^104.0|^105.0",
        "magento/module-payment": "^100.4|^101.0|^102.0",
        "magento/module-checkout": "^100.4|^101.0|^102.0",
        "magento/module-sales": "^103.0|^104.0|^105.0",
        "magento/module-store": "^101.0|^102.0|^103.0",
        "magento/module-directory": "^100.4|^101.0|^102.0",
        "giggsey/libphonenumber-for-php": "^8.13|^9.0",
        "ext-zlib": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5|^10.0",
        "magento/magento-coding-standard": "^5.0|^6.0"
    },
    "suggest": {
        "ext-curl": "For API communication with MoneyHash",
        "ext-json": "For processing JSON responses",
        "ext-openssl": "For secure encryption"
    },
    "conflict": {
        "magento/magento2-base": "<2.4.2"
    },
    "autoload": {
        "files": [
            "registration.php"
        ],
        "psr-4": {
            "MoneyHash\\Payment\\": ""
        }
    },
    "authors": [
        {
            "name": "MoneyHash",
            "email": "support@moneyhash.io",
            "homepage": "https://moneyhash.io",
            "role": "Individual"
        }
    ],
    "keywords": [
        "magento2",
        "payment",
        "payment-gateway",
        "moneyhash",
        "checkout",
        "ecommerce",
        "unified-payments",
        "africa",
        "middle-east",
        "payment-processing"
    ],
    "support": {
        "email": "support@moneyhash.io",
        "issues": "https://github.com/moneyhash/magento2-payment/issues",
        "docs": "https://docs.moneyhash.io/docs/magento-2",
        "source": "https://github.com/moneyhash/magento2-payment",
        "chat": "https://moneyhash.io/contact"
    },
    "homepage": "https://moneyhash.io"
}
