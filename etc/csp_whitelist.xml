<!--
/**
 * This file whitelists the domain for the external JS SDK.
 */
-->
<csp_whitelist xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
               xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Csp:etc/csp_whitelist.xsd">
    <policies>
        <policy id="script-src">
            <values>
                <value id="jsdelivr" type="host">cdn.jsdelivr.net</value>
                <value id="moneyhash-cdn" type="host">*.moneyhash.io</value>
            </values>
        </policy>

        <policy id="img-src">
            <values>
                <value id="moneyhash-cdn" type="host">*.moneyhash.io</value>
            </values>
        </policy>
        <policy id="frame-src">
            <values>
                <value id="moneyhash-cdn" type="host">*.moneyhash.io</value>
            </values>
        </policy>
    </policies>
</csp_whitelist>
