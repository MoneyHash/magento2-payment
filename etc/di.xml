<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">
    <preference for="MoneyHash\Payment\Api\Data\WebhookInterface" type="MoneyHash\Payment\Model\Data\Webhook"/>
    <preference for="MoneyHash\Payment\Api\IntentManagementInterface" type="MoneyHash\Payment\Model\IntentManagement"/>
    <preference for="MoneyHash\Payment\Api\Service\SignatureValidatorInterface"
                type="MoneyHash\Payment\Model\Service\SignatureValidator"/>
    <preference for="MoneyHash\Payment\Api\Service\OrderProcessorInterface"
                type="MoneyHash\Payment\Model\Service\OrderProcessor"/>
    <preference for="MoneyHash\Payment\Api\Service\PaymentCaptureServiceInterface"
                type="MoneyHash\Payment\Model\Service\PaymentCaptureService"/>
    <preference for="MoneyHash\Payment\Api\Data\WebhookTransactionInterface"
                type="MoneyHash\Payment\Model\WebhookTransaction"/>
    <preference for="MoneyHash\Payment\Api\WebhookTransactionRepositoryInterface"
                type="MoneyHash\Payment\Model\WebhookTransactionRepository"/>

    <preference for="Magento\Payment\Gateway\Data\Quote\QuoteAdapter" type="MoneyHash\Payment\Model\QuoteAdapter"/>
    <preference for="Magento\Payment\Gateway\Data\Order\OrderAdapter" type="MoneyHash\Payment\Model\OrderAdapter"/>

    <virtualType name="MoneyHashAllFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">MoneyHash\Payment\Model\Ui\ConfigProvider::CODE_ALL</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">MoneyHash\Payment\Block\Info</argument>
            <argument name="valueHandlerPool" xsi:type="object">MoneyHashAllValueHandlerPool</argument>
            <argument name="commandPool" xsi:type="object">MoneyHashAllCommandPool</argument>
        </arguments>
    </virtualType>
    <!-- COMMANDS -->
    <virtualType name="MoneyHashAllCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="create_intent" xsi:type="string">MoneyHashAllCreateIntentCommand</item>
                <item name="authorize" xsi:type="string">MoneyHashAllAuthorizeCommand</item>
                <item name="capture" xsi:type="string">MoneyHashAllCaptureCommand</item>
                <item name="void" xsi:type="string">MoneyHashAllVoidCommand</item>
                <item name="cancel" xsi:type="string">MoneyHashAllVoidCommand</item>
                <item name="refund" xsi:type="string">MoneyHashAllRefundCommand</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="MoneyHashAllCreateIntentCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">MoneyHashAllCreateIntentRequest</argument>
            <argument name="transferFactory" xsi:type="object">MoneyHash\Payment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">MoneyHash\Payment\Gateway\Http\Client\Client</argument>
            <argument name="validator" xsi:type="object">MoneyHash\Payment\Gateway\Validator\IntentValidator</argument>
            <argument name="handler" xsi:type="object">MoneyHash\Payment\Gateway\Response\IntentIdHandler</argument>
        </arguments>
    </virtualType>
    <virtualType name="MoneyHashAllCreateIntentRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="endpoint" xsi:type="string">IntentEndpointBuilder</item>
                <item name="order_data" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\OrderData</item>
                <item name="flow_id" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\FlowIdData</item>
                <item name="webhook_url" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\WebhookData</item>
                <item name="custom_data" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\CustomData</item>
                <item name="language" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\Language</item>
                <!--<item name="operation" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\OperationData</item>-->
                <item name="billing_data" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\BillingData</item>
                <item name="shipping_data" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\ShippingData
                </item>
                <item name="product_items" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\ProductItems
                </item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="IntentEndpointBuilder" type="MoneyHash\Payment\Gateway\Request\Builder\EndpointData">
        <arguments>
            <argument name="endpoint" xsi:type="const">MoneyHash\Payment\Gateway\Request\Endpoint::INTENT</argument>
        </arguments>
    </virtualType>
    <!-- Will handle Get Intent details as authorize command to check intent status -->
    <virtualType name="MoneyHashAllAuthorizeCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">MoneyHashAllAuthorizationRequest</argument>
            <argument name="transferFactory" xsi:type="object">GetTransferFactory</argument>
            <argument name="client" xsi:type="object">MoneyHash\Payment\Gateway\Http\Client\Client</argument>
            <argument name="validator" xsi:type="object">MoneyHash\Payment\Gateway\Validator\PaymentValidator</argument>
            <argument name="handler" xsi:type="object">MoneyHash\Payment\Gateway\Response\TransactionIdHandler
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="MoneyHashAllAuthorizationRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="endpoint" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\GetIntentData</item>
            </argument>
        </arguments>
    </virtualType>
    <!-- Capture Command -->
    <virtualType name="MoneyHashAllCaptureCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">MoneyHashCaptureRequest</argument>
            <argument name="transferFactory" xsi:type="object">MoneyHash\Payment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">MoneyHash\Payment\Gateway\Http\Client\Client</argument>
            <!--<argument name="validator" xsi:type="object">MoneyHash\Payment\Gateway\Validator\IntentValidator</argument>
            <argument name="handler" xsi:type="object">MoneyHash\Payment\Gateway\Response\IntentIdHandler</argument>-->
        </arguments>
    </virtualType>
    <virtualType name="MoneyHashCaptureRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="endpoint" xsi:type="string">CaptureTransactionEndpoint</item>
                <item name="amount" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\OrderData</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="CaptureTransactionEndpoint"
                 type="MoneyHash\Payment\Gateway\Request\Builder\TransactionEndpointData">
        <arguments>
            <argument name="command" xsi:type="const">
                MoneyHash\Payment\Gateway\Request\Builder\TransactionEndpointData::CAPTURE_COMMAND
            </argument>
        </arguments>
    </virtualType>
    <!-- Void Command -->
    <virtualType name="MoneyHashAllVoidCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">MoneyHashVoidRequest</argument>
            <argument name="transferFactory" xsi:type="object">MoneyHash\Payment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">MoneyHash\Payment\Gateway\Http\Client\Client</argument>
            <!--<argument name="validator" xsi:type="object">MoneyHash\Payment\Gateway\Validator\IntentValidator</argument>
            <argument name="handler" xsi:type="object">MoneyHash\Payment\Gateway\Response\IntentIdHandler</argument>-->
        </arguments>
    </virtualType>

    <virtualType name="MoneyHashVoidRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="endpoint" xsi:type="string">
                    MoneyHash\Payment\Gateway\Request\Builder\TransactionEndpointData
                </item>
                <item name="amount" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\OrderData</item>
            </argument>
        </arguments>
    </virtualType>
    <!-- Refund Command -->
    <virtualType name="MoneyHashAllRefundCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">MoneyHashRefundRequest</argument>
            <argument name="transferFactory" xsi:type="object">MoneyHash\Payment\Gateway\Http\TransferFactory</argument>
            <argument name="client" xsi:type="object">MoneyHash\Payment\Gateway\Http\Client\Client</argument>
            <!--<argument name="validator" xsi:type="object">MoneyHash\Payment\Gateway\Validator\IntentValidator</argument>
            <argument name="handler" xsi:type="object">MoneyHash\Payment\Gateway\Response\IntentIdHandler</argument>-->
        </arguments>
    </virtualType>
    <virtualType name="MoneyHashRefundRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="endpoint" xsi:type="string">RefundTransactionEndpoint</item>
                <item name="amount" xsi:type="string">MoneyHash\Payment\Gateway\Request\Builder\OrderData</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="RefundTransactionEndpoint"
                 type="MoneyHash\Payment\Gateway\Request\Builder\TransactionEndpointData">
        <arguments>
            <argument name="command" xsi:type="const">
                MoneyHash\Payment\Gateway\Request\Builder\TransactionEndpointData::REFUND_COMMAND
            </argument>
        </arguments>
    </virtualType>
    <!-- Value Handler -->
    <virtualType name="MoneyHashAllValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">MoneyHashAllConfigValueHandlerAll</item>
            </argument>
        </arguments>
    </virtualType>
    <!-- Config Handlers -->
    <virtualType name="MoneyHashAllConfigValueHandlerAll" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">MoneyHashAllConfig</argument>
        </arguments>
    </virtualType>
    <!-- Configs -->
    <virtualType name="MoneyHashAllConfig" type="Magento\Payment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">MoneyHash\Payment\Model\Ui\ConfigProvider::CODE_ALL</argument>
        </arguments>
    </virtualType>
    <type name="MoneyHash\Payment\Model\IntentManagement">
        <arguments>
            <argument name="commandPool" xsi:type="object">MoneyHashAllCommandPool</argument>
        </arguments>
    </type>
    <virtualType name="GetTransferFactory" type="MoneyHash\Payment\Gateway\Http\TransferFactory">
        <arguments>
            <argument name="method" xsi:type="string">GET</argument>
        </arguments>
    </virtualType>
    <type name="MoneyHash\Payment\Model\Ui\ConfigProvider">
        <arguments>
            <argument name="config" xsi:type="object">MoneyHashAllConfig</argument>
        </arguments>
    </type>

    <!--<type name="MoneyHash\Payment\Model\Config\Backend\ApiKey">
        <arguments>
            <argument name="transferFactory" xsi:type="object">GetTransferFactory</argument>
        </arguments>
    </type>-->
    <virtualType name="WebhookLogger" type="MoneyHash\Payment\Model\Logger">
        <arguments>
            <argument name="fileName" xsi:type="string">webhook_%s.log</argument>
        </arguments>
    </virtualType>
    <virtualType name="ClientLogger" type="MoneyHash\Payment\Model\Logger">
        <arguments>
            <argument name="fileName" xsi:type="string">client_%s.log</argument>
        </arguments>
    </virtualType>
    <type name="MoneyHash\Payment\Controller\Payment\Webhook">
        <arguments>
            <argument name="logger" xsi:type="object">WebhookLogger</argument>
        </arguments>
    </type>
    <type name="MoneyHash\Payment\Observer\ProcessWebhookAfterOrderObserver">
        <arguments>
            <argument name="logger" xsi:type="object">WebhookLogger</argument>
        </arguments>
    </type>
    <type name="MoneyHash\Payment\Gateway\Http\Client\Client">
        <arguments>
            <argument name="logger" xsi:type="object">ClientLogger</argument>
        </arguments>
    </type>
</config>
